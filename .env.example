# ---- Prox challenge — required ----
#
# One Anthropic API key. That's the entire config surface.
# Get one at https://console.anthropic.com/settings/keys
# The key must have access to Claude Opus 4.7 (`claude-opus-4-7`).
#
# Usage from a fresh clone:
#   cp .env.example .env
#   # paste your key below on the right of the `=`
#   npm install
#   npm run dev
ANTHROPIC_API_KEY=sk-ant-...
